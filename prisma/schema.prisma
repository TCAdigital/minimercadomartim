generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  oldPrice    Float?
  image       String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id          String   @id @default(uuid())
  title       String
  highlight   String
  subtitle    String
  description String
  image       String
  bgColor     String
  topBadge    String?
  badgeText   String?
  badgeIcon   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromoSlide {
  id             String   @id @default(uuid())
  tag            String
  title          String
  highlight      String
  description    String
  buttonText     String
  image          String
  bgColor        String   @default("#1a1a1a")
  tagColor       String   @default("bg-[var(--color-brand-orange)]")
  highlightColor String   @default("text-[var(--color-brand-yellow)]")
  buttonColor    String   @default("bg-[var(--color-brand-green)]")
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
