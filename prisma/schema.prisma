generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  oldPrice    Float?
  image       String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id          String   @id @default(uuid())
  title       String
  highlight   String
  subtitle    String
  description String
  image       String
  bgColor     String
  topBadge    String?
  badgeText   String?
  badgeIcon   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromoSlide {
  id             String   @id @default(uuid())
  type           String   @default("MEIO") // "TOPO" ou "MEIO"
  tag            String
  title          String
  highlight      String
  description    String?
  buttonText     String
  href           String   @default("/#produtos")
  image          String
  bgColor        String   @default("#619d24")
  textColor      String   @default("#ffffff")
  buttonBgColor  String   @default("#ffffff")
  buttonTextColor String  @default("#619d24")
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
